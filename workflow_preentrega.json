      "parameters": {
        "jsCode": "// 1. Extraer el contenido del cuerpo que tiene los caracteres \\n\nconst rawBody = $json.body;\n\n// 2. Limpiar la cadena y convertirla en un objeto JSON real\n// Reemplazamos los saltos de línea y quitamos comas sobrantes antes del cierre\nconst cleanJson = JSON.parse(rawBody.replace(/\\\\n/g, '').replace(/,\\s*}/, '}'));\n\n// 3. Generar la fecha y hora actuales usando Luxon (integrado en n8n)\nconst ahora = DateTime.now();\nconst fechaTicket = ahora.toFormat('yyyyMMdd');\nconst horaActual = ahora.toFormat('HH:mm:ss');\n\n// 4. Retornar los campos separados y el ticket dinámico\nreturn {\n  email: cleanJson.email,\n  usuario: cleanJson.usuario,\n  tipo_problema: cleanJson.tipo_problema,\n  nivel_escalamiento: cleanJson.nivel_escalamiento,\n  hora: horaActual,\n  ticket: `TK${fechaTicket}-${cleanJson.usuario}`\n};"
      },
